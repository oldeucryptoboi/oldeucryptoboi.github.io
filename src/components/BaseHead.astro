---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	type?: 'website' | 'article';
	pubDate?: Date;
	updatedDate?: Date;
	tags?: string[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image, type = 'website', pubDate, updatedDate, tags = [] } = Astro.props;

const siteJsonLd = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Laurent DeSegur",
	"url": "https://oldeucryptoboi.com",
	"description": "AI agents, deterministic runtimes, and the code that runs them. Building KarnEvil9, Tarkus, and LAID.",
	"sameAs": [
		"https://x.com/oldeucryptoboi",
		"https://github.com/oldeucryptoboi",
		"https://oldeucryptoboi.substack.com"
	],
	"knowsAbout": [
		"AI Agents",
		"AI Governance",
		"AI Safety",
		"Deterministic Runtimes",
		"Multi-Agent Systems",
		"TypeScript",
		"Open Source"
	]
};

const articleJsonLd = type === 'article' && pubDate ? {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"headline": title,
	"description": description,
	"url": canonicalURL.href,
	...(image ? { "image": new URL(image.src, Astro.url).href } : {}),
	"datePublished": pubDate.toISOString(),
	...(updatedDate ? { "dateModified": updatedDate.toISOString() } : {}),
	"author": {
		"@type": "Person",
		"name": "Laurent DeSegur",
		"url": "https://oldeucryptoboi.com"
	},
	"publisher": {
		"@type": "Person",
		"name": "Laurent DeSegur",
		"url": "https://oldeucryptoboi.com"
	},
	"keywords": tags.join(", "),
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": canonicalURL.href
	}
} : null;
---

<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-87345ZT63C"></script>
<script>
	window.dataLayer = window.dataLayer || [];
	function gtag(){dataLayer.push(arguments);}
	gtag('js', new Date());
	gtag('config', 'G-87345ZT63C');
</script>

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />
<meta name="google-site-verification" content="52SuCTLEd4SGPIPPtQYzdw7gQmWY1-O4AIzqO-d37GM" />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap" rel="stylesheet" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{image && <meta property="og:image" content={new URL(image.src, Astro.url)} />}
<meta property="og:site_name" content="Laurent DeSegur" />
{type === 'article' && pubDate && (
	<>
		<meta property="article:published_time" content={pubDate.toISOString()} />
		{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
		{tags.map((tag) => <meta property="article:tag" content={tag} />)}
		<meta property="article:author" content="https://oldeucryptoboi.com/about" />
	</>
)}

<!-- Twitter -->
<meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{image && <meta name="twitter:image" content={new URL(image.src, Astro.url)} />}
<meta name="twitter:site" content="@oldeucryptoboi" />
<meta name="twitter:creator" content="@oldeucryptoboi" />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />
{articleJsonLd && (
	<script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
)}
