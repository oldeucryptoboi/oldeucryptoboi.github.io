---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="status-line">
			<span class="hal-dot"></span>
			<span>OPERATIONAL</span>
		</div>
		<div class="copyright">
			&copy; {today.getFullYear()} oldcryptoboi
		</div>
		<div class="social-links">
			<a href="https://x.com/oldeucryptoboi" target="_blank">X</a>
			<span class="sep">/</span>
			<a href="https://oldeucryptoboi.substack.com" target="_blank">Substack</a>
			<span class="sep">/</span>
			<a href="https://github.com/oldeucryptoboi" target="_blank">GitHub</a>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1.5em 4em;
		background: var(--bg);
		border-top: 1px solid var(--border);
		color: var(--text-dim);
		font-size: 0.8em;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		font-family: "Atkinson", sans-serif;
	}
	.footer-inner {
		max-width: 740px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.status-line {
		display: flex;
		align-items: center;
		gap: 0.5em;
		color: var(--text-dim);
	}
	.hal-dot {
		display: inline-block;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--hal-red);
		box-shadow: 0 0 6px var(--hal-red);
	}
	.social-links a {
		color: var(--text-dim);
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.social-links a:hover {
		color: var(--hal-red);
	}
	.sep {
		color: var(--border-light);
		margin: 0 0.3em;
	}
	@media (max-width: 720px) {
		.footer-inner {
			flex-direction: column;
			gap: 1em;
			text-align: center;
		}
	}
</style>
