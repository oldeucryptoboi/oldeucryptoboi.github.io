---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="site-title" href="/">
			<span class="hal-eye"></span>
			<span>Laurent DeSegur</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/course">Course</HeaderLink>
			<HeaderLink href="/consulting">Consulting</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://x.com/oldeucryptoboi" target="_blank" aria-label="X">
				<svg viewBox="0 0 24 24" width="18" height="18"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
			</a>
			<a href="https://oldeucryptoboi.substack.com" target="_blank" aria-label="Substack">
				<svg viewBox="0 0 24 24" width="18" height="18"><path fill="currentColor" d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>
			</a>
			<a href="https://github.com/oldeucryptoboi" target="_blank" aria-label="GitHub">
				<svg viewBox="0 0 16 16" width="18" height="18"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: var(--bg);
		border-bottom: 1px solid var(--border);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 740px;
		margin: 0 auto;
	}
	.site-title {
		display: flex;
		align-items: center;
		gap: 0.6em;
		text-decoration: none;
		color: #e0e0e0;
		font-family: "Oswald", "Atkinson", sans-serif;
		font-weight: 700;
		font-size: 1.1em;
		letter-spacing: 0.25em;
		text-transform: uppercase;
		padding: 1em 0;
	}
	.site-title:hover {
		color: #fff;
		text-shadow: 0 0 12px rgba(255, 51, 51, 0.3);
	}
	.hal-eye {
		display: inline-block;
		width: 18px;
		height: 18px;
		border-radius: 50%;
		background: radial-gradient(
			circle at 40% 38%,
			#ffaaaa 0%,
			#ff4444 18%,
			#cc0000 45%,
			#660000 72%,
			#220000 100%
		);
		box-shadow:
			0 0 6px rgba(255, 50, 50, 0.8),
			0 0 16px rgba(255, 50, 50, 0.4),
			0 0 30px rgba(255, 50, 50, 0.15);
		flex-shrink: 0;
		position: relative;
		border: 1px solid #440000;
	}
	.hal-eye::after {
		content: '';
		position: absolute;
		top: 3px;
		left: 4px;
		width: 5px;
		height: 4px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(255,200,200,0.7) 0%, transparent 100%);
	}
	.internal-links {
		display: flex;
		gap: 0;
	}
	nav a {
		padding: 1em 0.75em;
		color: var(--text-dim);
		text-decoration: none;
		font-size: 0.8em;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		font-family: "Atkinson", sans-serif;
		transition: color 0.2s ease;
		border-bottom: 2px solid transparent;
	}
	nav a:hover {
		color: var(--text);
		text-shadow: none;
	}
	nav a.active {
		color: var(--hal-red);
		border-bottom-color: var(--hal-red);
	}
	.social-links {
		display: flex;
		gap: 0.25em;
	}
	.social-links a {
		padding: 0.75em 0.5em;
		color: var(--text-dim);
		border-bottom: none;
	}
	.social-links a:hover {
		color: var(--hal-red);
		text-shadow: none;
	}
	@media (max-width: 720px) {
		.social-links { display: none; }
		nav a { padding: 1em 0.5em; font-size: 0.75em; }
	}
</style>
