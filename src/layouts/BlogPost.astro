---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	prev?: CollectionEntry<'blog'> | null;
	next?: CollectionEntry<'blog'> | null;
};

const { title, description, pubDate, updatedDate, heroImage, tags = [], prev, next } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} type="article" pubDate={pubDate} updatedDate={updatedDate} tags={tags} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose {
				width: 740px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--text);
			}
			.article-header {
				margin-bottom: 2em;
				padding: 2em 0;
				border-bottom: 1px solid var(--border);
			}
			.article-header .date {
				color: var(--text-dim);
				font-size: 0.8em;
				letter-spacing: 0.04em;
				margin-bottom: 0.75em;
			}
			.article-header .last-updated-on {
				font-style: italic;
			}
			.article-header h1 {
				margin: 0;
				font-size: 2em;
				color: #e0e0e0;
				text-transform: none;
				letter-spacing: 0.02em;
				line-height: 1.25;
			}
			.tags {
				display: flex;
				gap: 0.5em;
				flex-wrap: wrap;
				margin-top: 1em;
			}
			.tags span {
				font-size: 0.65em;
				padding: 0.15em 0.5em;
				border: 1px solid var(--border-light);
				color: var(--text-dim);
				letter-spacing: 0.04em;
				text-transform: uppercase;
				font-family: "Atkinson", sans-serif;
			}
			.post-nav {
				display: flex;
				justify-content: space-between;
				margin-top: 3em;
				padding-top: 2em;
				border-top: 1px solid var(--border);
				gap: 2em;
			}
			.nav-link {
				display: flex;
				flex-direction: column;
				gap: 0.3em;
				text-decoration: none;
				max-width: 45%;
				transition: background 0.15s ease;
			}
			.nav-link:hover .nav-title {
				color: var(--hal-red);
			}
			.nav-next {
				text-align: right;
				margin-left: auto;
			}
			.nav-label {
				font-size: 0.7em;
				color: var(--text-dim);
				letter-spacing: 0.08em;
				text-transform: uppercase;
				font-family: "Atkinson", sans-serif;
			}
			.nav-title {
				color: var(--text);
				font-size: 0.9em;
				line-height: 1.4;
				transition: color 0.15s ease;
			}
			@media (max-width: 720px) {
				.post-nav {
					flex-direction: column;
					gap: 1.5em;
				}
				.nav-link {
					max-width: 100%;
				}
				.nav-next {
					text-align: left;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="article-header">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Updated <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{tags.length > 0 && (
							<div class="tags">
								{tags.map((tag: string) => <span>{tag}</span>)}
							</div>
						)}
					</div>
					<slot />
					{(prev || next) && (
						<nav class="post-nav">
							{prev ? (
								<a class="nav-link nav-prev" href={`/blog/${prev.id}/`}>
									<span class="nav-label">Previous</span>
									<span class="nav-title">{prev.data.title}</span>
								</a>
							) : <span />}
							{next ? (
								<a class="nav-link nav-next" href={`/blog/${next.id}/`}>
									<span class="nav-label">Next</span>
									<span class="nav-title">{next.data.title}</span>
								</a>
							) : <span />}
						</nav>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
