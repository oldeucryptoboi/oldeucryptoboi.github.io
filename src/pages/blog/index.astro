---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description="Articles on AI agents, deterministic runtimes, and building in public" />
		<style>
			.page-header {
				margin-bottom: 2.5em;
				padding-bottom: 1em;
				border-bottom: 1px solid var(--border);
			}
			.page-header h1 {
				font-size: 1em;
				margin-bottom: 0.3em;
				color: var(--hal-red);
				letter-spacing: 0.1em;
			}
			.page-header p {
				color: var(--text-dim);
				font-size: 0.85em;
				margin: 0;
			}
			.subscribe-line {
				margin-top: 0.6em !important;
			}
			.subscribe-line a {
				color: var(--hal-red);
				font-size: 0.8em;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				font-family: "Atkinson", sans-serif;
				text-decoration: none;
				transition: color 0.15s ease;
			}
			.subscribe-line a:hover {
				color: #fff;
			}
			.posts {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.posts li a {
				display: block;
				padding: 1.25em 0;
				border-bottom: 1px solid var(--border);
				text-decoration: none;
				transition: background 0.15s ease;
			}
			.posts li a:hover {
				background: var(--hal-red-subtle);
			}
			.posts li a:hover h4 {
				color: #fff;
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.75em;
				margin-bottom: 0.3em;
			}
			.indicator {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--hal-red);
				flex-shrink: 0;
			}
			.posts h4 {
				margin: 0;
				color: var(--text);
				font-size: 1em;
				font-family: "Atkinson", sans-serif;
				text-transform: none;
				letter-spacing: 0.02em;
				line-height: 1.3;
				transition: color 0.15s ease;
			}
			.posts .date {
				color: var(--text-dim);
				font-size: 0.75em;
				letter-spacing: 0.04em;
			}
			.posts .description {
				color: var(--text-muted);
				font-size: 0.85em;
				margin: 0.4em 0 0;
				line-height: 1.5;
			}
			.posts .tags {
				display: flex;
				gap: 0.5em;
				flex-wrap: wrap;
				margin-top: 0.6em;
			}
			.posts .tags span {
				font-size: 0.65em;
				padding: 0.15em 0.5em;
				border: 1px solid var(--border-light);
				color: var(--text-dim);
				letter-spacing: 0.04em;
				text-transform: uppercase;
				font-family: "Atkinson", sans-serif;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Transmissions</h1>
				<p>AI agents, deterministic execution, building in public.</p>
				<p class="subscribe-line"><a href="https://oldeucryptoboi.substack.com/subscribe" target="_blank" rel="noopener">Subscribe on Substack →</a></p>
			</div>
			<ul class="posts">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							<div class="post-meta">
								<span class="indicator"></span>
								<h4>{post.data.title}</h4>
							</div>
							<span class="date"><FormattedDate date={post.data.pubDate} /></span>
							<p class="description">{post.data.description}</p>
							{post.data.tags.length > 0 && (
								<div class="tags">
									{post.data.tags.map((tag: string) => <span>{tag}</span>)}
								</div>
							)}
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
