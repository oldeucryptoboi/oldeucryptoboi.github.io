---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description="Articles on AI agents, deterministic runtimes, and building in public" />
		<style>
			.page-header {
				margin-bottom: 2em;
			}
			.page-header h1 {
				font-size: 2.5em;
				margin-bottom: 0.25em;
			}
			.page-header p {
				color: var(--text-muted);
				font-size: 1.1em;
			}
			.posts {
				display: flex;
				flex-direction: column;
				gap: 1.5em;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.posts li a {
				display: block;
				padding: 1.5em;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 8px;
				text-decoration: none;
				transition: border-color 0.2s ease, box-shadow 0.2s ease;
			}
			.posts li a:hover {
				border-color: var(--accent);
				box-shadow: 0 0 20px var(--accent-glow);
			}
			.posts h4 {
				margin: 0 0 0.25em;
				color: var(--text);
				font-size: 1.2em;
				line-height: 1.3;
			}
			.posts .date {
				color: var(--text-dim);
				font-size: 0.85em;
			}
			.posts .description {
				color: var(--text-muted);
				font-size: 0.9em;
				margin-top: 0.5em;
				line-height: 1.5;
			}
			.posts .tags {
				display: flex;
				gap: 0.5em;
				flex-wrap: wrap;
				margin-top: 0.75em;
			}
			.posts .tags span {
				font-size: 0.7em;
				padding: 0.15em 0.5em;
				background: rgba(0, 212, 255, 0.1);
				border: 1px solid rgba(0, 212, 255, 0.2);
				border-radius: 4px;
				color: var(--accent);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Blog</h1>
				<p>Writing about AI agents, deterministic execution, and building in public.</p>
			</div>
			<ul class="posts">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							<h4>{post.data.title}</h4>
							<span class="date"><FormattedDate date={post.data.pubDate} /></span>
							<p class="description">{post.data.description}</p>
							{post.data.tags.length > 0 && (
								<div class="tags">
									{post.data.tags.map((tag: string) => <span>{tag}</span>)}
								</div>
							)}
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
