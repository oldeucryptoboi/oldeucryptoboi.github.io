---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const projects = [
	{
		name: 'KarnEvil9',
		description: 'Deterministic AI agent runtime. Reference implementation of Google DeepMind\'s Intelligent AI Delegation framework — hash-chain journals, escrow bonds, futility monitoring, P2P delegation mesh.',
		url: 'https://github.com/oldeucryptoboi/KarnEvil9',
		tags: ['TypeScript', 'AI Agents', 'Delegation'],
	},
	{
		name: 'Tarkus',
		description: 'Personal PR agent. Publishes markdown to Substack, generates social media posts, cross-posts to X. The CLI that powers the content pipeline.',
		url: 'https://github.com/oldeucryptoboi/md2substack',
		tags: ['TypeScript', 'CLI', 'Automation'],
	},
	{
		name: 'LAID',
		description: 'LinkedIn AI Detector. Chrome extension that scores posts 0-100 using 14 heuristic signals backed by peer-reviewed research. Runs locally, no API key needed.',
		url: 'https://github.com/oldeucryptoboi/linkedin-ai-detector',
		tags: ['Chrome Extension', 'AI Detection', 'Heuristics'],
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 4em 0 3em;
			}
			.hero h1 {
				font-size: 3.5em;
				margin-bottom: 0.25em;
				background: linear-gradient(135deg, var(--accent), #a78bfa);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.hero .tagline {
				font-size: 1.25em;
				color: var(--text-muted);
				max-width: 600px;
				margin: 0 auto;
				line-height: 1.6;
			}
			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 1.5em;
				border-bottom: 1px solid var(--border);
				padding-bottom: 0.5em;
			}
			.section-header h2 {
				font-size: 1.5em;
				margin: 0;
			}
			.section-header a {
				font-size: 0.9em;
				text-decoration: none;
			}
			section {
				margin-bottom: 3em;
			}

			/* Posts */
			.posts {
				display: flex;
				flex-direction: column;
				gap: 1.5em;
			}
			.post-card {
				display: block;
				padding: 1.25em 1.5em;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 8px;
				text-decoration: none;
				transition: border-color 0.2s ease, box-shadow 0.2s ease;
			}
			.post-card:hover {
				border-color: var(--accent);
				box-shadow: 0 0 20px var(--accent-glow);
			}
			.post-card h4 {
				margin: 0 0 0.25em;
				color: var(--text);
				font-size: 1.1em;
			}
			.post-card .date {
				color: var(--text-dim);
				font-size: 0.85em;
			}
			.post-card .description {
				color: var(--text-muted);
				font-size: 0.9em;
				margin-top: 0.5em;
				line-height: 1.5;
			}

			/* Projects */
			.projects {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.5em;
			}
			.project-card {
				display: block;
				padding: 1.5em;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 8px;
				text-decoration: none;
				transition: border-color 0.2s ease, box-shadow 0.2s ease;
			}
			.project-card:hover {
				border-color: var(--accent);
				box-shadow: 0 0 20px var(--accent-glow);
			}
			.project-card h4 {
				margin: 0 0 0.5em;
				color: var(--accent);
				font-size: 1.2em;
			}
			.project-card p {
				color: var(--text-muted);
				margin: 0 0 0.75em;
				font-size: 0.9em;
				line-height: 1.5;
			}
			.project-tags {
				display: flex;
				gap: 0.5em;
				flex-wrap: wrap;
			}
			.project-tags span {
				font-size: 0.75em;
				padding: 0.2em 0.6em;
				background: rgba(0, 212, 255, 0.1);
				border: 1px solid rgba(0, 212, 255, 0.2);
				border-radius: 4px;
				color: var(--accent);
			}

			@media (max-width: 720px) {
				.hero h1 {
					font-size: 2.5em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>oldcryptoboi</h1>
				<p class="tagline">
					AI agents, deterministic runtimes, and the code that runs them.
				</p>
			</div>

			<section>
				<div class="section-header">
					<h2>Latest Posts</h2>
					<a href="/blog">View all &rarr;</a>
				</div>
				<div class="posts">
					{posts.map((post) => (
						<a class="post-card" href={`/blog/${post.id}/`}>
							<h4>{post.data.title}</h4>
							<span class="date"><FormattedDate date={post.data.pubDate} /></span>
							<p class="description">{post.data.description}</p>
						</a>
					))}
				</div>
			</section>

			<section>
				<div class="section-header">
					<h2>Projects</h2>
					<a href="/projects">View all &rarr;</a>
				</div>
				<div class="projects">
					{projects.map((project) => (
						<a class="project-card" href={project.url} target="_blank">
							<h4>{project.name}</h4>
							<p>{project.description}</p>
							<div class="project-tags">
								{project.tags.map((tag) => <span>{tag}</span>)}
							</div>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
