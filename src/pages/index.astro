---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const projects = [
	{
		name: 'KarnEvil9',
		description: 'Deterministic AI agent runtime. Reference implementation of Google DeepMind\'s Intelligent AI Delegation framework.',
		url: 'https://github.com/oldeucryptoboi/KarnEvil9',
		status: 'ACTIVE',
	},
	{
		name: 'Manticore',
		description: 'Content publishing CLI. Publishes markdown to Substack, generates social posts, deploys articles to this site.',
		url: 'https://github.com/oldeucryptoboi/md2substack',
		status: 'ACTIVE',
	},
	{
		name: 'LAID',
		description: 'LinkedIn AI Detector. Chrome extension — 14 heuristic signals, peer-reviewed research, optional LLM layer.',
		url: 'https://github.com/oldeucryptoboi/linkedin-ai-detector',
		status: 'ACTIVE',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 3em 0 4em;
				border-bottom: 1px solid var(--border);
				margin-bottom: 3em;
			}
			@keyframes hal-pulse {
				0%, 100% {
					text-shadow:
						0 0 10px rgba(255, 51, 51, 0.4),
						0 0 40px rgba(255, 51, 51, 0.15),
						0 0 80px rgba(255, 51, 51, 0.05);
				}
				50% {
					text-shadow:
						0 0 15px rgba(255, 51, 51, 0.6),
						0 0 50px rgba(255, 51, 51, 0.25),
						0 0 100px rgba(255, 51, 51, 0.1);
				}
			}
			.hero h1 {
				font-family: "Oswald", "Atkinson", sans-serif;
				font-size: 3.2em;
				margin-bottom: 0.3em;
				letter-spacing: 0.3em;
				color: #e0e0e0;
				text-shadow:
					0 0 10px rgba(255, 51, 51, 0.4),
					0 0 40px rgba(255, 51, 51, 0.15),
					0 0 80px rgba(255, 51, 51, 0.05);
				animation: hal-pulse 4s ease-in-out infinite;
			}
			.hero .tagline {
				font-size: 0.95em;
				color: var(--text-dim);
				max-width: 500px;
				margin: 0 auto;
				line-height: 1.6;
				letter-spacing: 0.04em;
			}

			/* Sections */
			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1.5em;
				padding-bottom: 0.75em;
				border-bottom: 1px solid var(--border);
			}
			.section-header h2 {
				font-size: 0.85em;
				margin: 0;
				color: var(--hal-red);
				letter-spacing: 0.1em;
			}
			.section-header a {
				font-size: 0.75em;
				color: var(--text-dim);
				text-decoration: none;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				font-family: "Atkinson", sans-serif;
			}
			.section-header a:hover {
				color: var(--hal-red);
			}
			section {
				margin-bottom: 3.5em;
			}

			/* Posts */
			.posts {
				display: flex;
				flex-direction: column;
				gap: 0;
			}
			.post-card {
				display: block;
				padding: 1.25em 0;
				border-bottom: 1px solid var(--border);
				text-decoration: none;
				transition: background 0.15s ease;
			}
			.post-card:hover {
				background: var(--hal-red-subtle);
			}
			.post-card:hover h4 {
				color: #fff;
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.75em;
				margin-bottom: 0.3em;
			}
			.post-card .indicator {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--hal-red);
				flex-shrink: 0;
			}
			.post-card h4 {
				margin: 0;
				color: var(--text);
				font-size: 1em;
				font-family: "Atkinson", sans-serif;
				text-transform: none;
				letter-spacing: 0.02em;
				transition: color 0.15s ease;
			}
			.post-card .date {
				color: var(--text-dim);
				font-size: 0.75em;
				letter-spacing: 0.04em;
			}
			.post-card .description {
				color: var(--text-muted);
				font-size: 0.85em;
				margin: 0.4em 0 0 0;
				line-height: 1.5;
			}

			/* Offerings */
			.offerings {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0;
			}
			.offering-card {
				display: block;
				padding: 1.25em 0;
				border-bottom: 1px solid var(--border);
				text-decoration: none;
				transition: background 0.15s ease;
			}
			.offering-card:first-child {
				border-right: 1px solid var(--border);
				padding-right: 1.5em;
			}
			.offering-card:last-child {
				padding-left: 1.5em;
			}
			.offering-card:hover {
				background: var(--hal-red-subtle);
			}
			.offering-card:hover h4 {
				color: #fff;
			}
			.offering-card h4 {
				margin: 0 0 0.4em;
				color: var(--hal-red);
				font-size: 0.9em;
				font-family: "Atkinson", sans-serif;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				transition: color 0.15s ease;
			}
			.offering-card p {
				color: var(--text-dim);
				font-size: 0.8em;
				margin: 0;
				line-height: 1.5;
			}

			/* Projects */
			.projects {
				display: flex;
				flex-direction: column;
				gap: 0;
			}
			.project-card {
				display: flex;
				align-items: baseline;
				gap: 1.5em;
				padding: 1em 0;
				border-bottom: 1px solid var(--border);
				text-decoration: none;
				transition: background 0.15s ease;
			}
			.project-card:hover {
				background: var(--hal-red-subtle);
			}
			.project-name {
				color: var(--hal-red);
				font-family: "Atkinson", sans-serif;
				font-weight: 700;
				font-size: 0.9em;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				white-space: nowrap;
				min-width: 120px;
			}
			.project-desc {
				color: var(--text-muted);
				font-size: 0.85em;
				line-height: 1.5;
				flex: 1;
			}
			.project-status {
				color: var(--text-dim);
				font-size: 0.7em;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				font-family: "Atkinson", sans-serif;
				white-space: nowrap;
			}

			@media (max-width: 720px) {
				.hero h1 { font-size: 2em; }
				.project-card { flex-direction: column; gap: 0.3em; }
				.project-status { display: none; }
				.offerings { grid-template-columns: 1fr; }
				.offering-card:first-child {
					border-right: none;
					padding-right: 0;
				}
				.offering-card:last-child {
					padding-left: 0;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>oldeucryptoboi</h1>
				<p class="tagline">
					AI agents, deterministic runtimes, and the code that runs them.
				</p>
			</div>

			<section>
				<div class="section-header">
					<h2>Latest Transmissions</h2>
					<a href="/blog">View all</a>
				</div>
				<div class="posts">
					{posts.map((post) => (
						<a class="post-card" href={`/blog/${post.id}/`}>
							<div class="post-meta">
								<span class="indicator"></span>
								<h4>{post.data.title}</h4>
							</div>
							<span class="date"><FormattedDate date={post.data.pubDate} /></span>
							<p class="description">{post.data.description}</p>
						</a>
					))}
				</div>
			</section>

			<section>
				<div class="section-header">
					<h2>Systems</h2>
					<a href="/projects">View all</a>
				</div>
				<div class="projects">
					{projects.map((project) => (
						<a class="project-card" href={project.url} target="_blank">
							<span class="project-name">{project.name}</span>
							<span class="project-desc">{project.description}</span>
							<span class="project-status">{project.status}</span>
						</a>
					))}
				</div>
			</section>

			<section>
				<div class="section-header">
					<h2>Services</h2>
				</div>
				<div class="offerings">
					<a class="offering-card" href="/course">
						<h4>Course</h4>
						<p>Building Deterministic AI Agent Systems — workshops and training on governance, safety, and deterministic runtime architecture.</p>
					</a>
					<a class="offering-card" href="/consulting">
						<h4>Consulting</h4>
						<p>Enterprise agent governance, safety architecture, and deterministic runtime implementation for production systems.</p>
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
