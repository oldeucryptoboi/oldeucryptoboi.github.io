---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const projects = [
	{
		name: 'KarnEvil9',
		status: 'ACTIVE',
		description: 'Deterministic AI agent runtime. The first public reference implementation of Google DeepMind\'s Intelligent AI Delegation framework. Hash-chain journals, escrow bonds, futility monitoring, Bayesian trust scoring, circuit breakers, P2P delegation mesh.',
		url: 'https://github.com/oldeucryptoboi/KarnEvil9',
		specs: [
			'SHA-256 hash-chain journal — tamper-evident audit trails',
			'FutilityMonitor — catches runaway agentic loops',
			'Graduated Authority — Bayesian trust scoring',
			'Escrow bonds — SLO-based slashing',
		],
	},
	{
		name: 'Tarkus',
		status: 'ACTIVE',
		description: 'Native macOS/iOS command center for monitoring and controlling EDDIE (KarnEvil9). Real-time session streaming, interactive approval cards, Bonjour server discovery.',
		url: 'https://github.com/oldeucryptoboi/Tarkus',
		specs: [
			'Native Swift — macOS and iOS',
			'Interactive permission approval cards',
			'Bonjour _karnevil9._tcp. auto-discovery',
			'WebSocket + SSE fallback with auto-reconnect',
		],
	},
	{
		name: 'LAID',
		status: 'ACTIVE',
		description: 'LinkedIn AI Detector. Chrome extension — 14 heuristic signals backed by peer-reviewed research. Runs in-browser by default. Optional LLM layer for nuanced analysis.',
		url: 'https://github.com/oldeucryptoboi/linkedin-ai-detector',
		specs: [
			'14 independent heuristic analyzers',
			'Contraction, em dash, epistemic analysis',
			'LLM rubric — 8 detection categories',
			'Zero-config local mode',
		],
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Open Source AI Agent Projects | ${SITE_TITLE}`} description="KarnEvil9 — deterministic AI agent runtime implementing Google DeepMind's Intelligent AI Delegation framework. Tarkus — native macOS/iOS command center for KarnEvil9. LAID — LinkedIn AI Detector with 14 peer-reviewed heuristic signals." />
		<style>
			.page-header {
				margin-bottom: 2.5em;
				padding-bottom: 1em;
				border-bottom: 1px solid var(--border);
			}
			.page-header h1 {
				font-size: 1em;
				margin-bottom: 0.3em;
				color: var(--hal-red);
				letter-spacing: 0.1em;
			}
			.page-header p {
				color: var(--text-dim);
				font-size: 0.85em;
				margin: 0;
			}
			.project {
				padding: 1.5em 0;
				border-bottom: 1px solid var(--border);
			}
			.project-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 0.75em;
			}
			.project-header h2 {
				font-size: 1em;
				margin: 0;
			}
			.project-header h2 a {
				color: var(--hal-red);
				text-decoration: none;
			}
			.project-header h2 a:hover {
				color: #ff6666;
			}
			.project-status {
				font-size: 0.65em;
				color: var(--text-dim);
				letter-spacing: 0.08em;
				font-family: "Atkinson", sans-serif;
				display: flex;
				align-items: center;
				gap: 0.5em;
			}
			.project-status .dot {
				width: 5px;
				height: 5px;
				border-radius: 50%;
				background: var(--hal-red);
				box-shadow: 0 0 4px var(--hal-red);
			}
			.project p {
				color: var(--text-muted);
				font-size: 0.85em;
				line-height: 1.6;
				margin: 0 0 1em;
			}
			.specs {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.specs li {
				padding: 0.25em 0;
				color: var(--text-dim);
				font-size: 0.8em;
			}
			.specs li::before {
				content: '>';
				color: var(--hal-red);
				margin-right: 0.75em;
				font-weight: 700;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Systems</h1>
				<p>Open-source tools for AI agents, content automation, and detection.</p>
			</div>

			{projects.map((project) => (
				<div class="project">
					<div class="project-header">
						<h2><a href={project.url} target="_blank">{project.name}</a></h2>
						<span class="project-status"><span class="dot"></span> {project.status}</span>
					</div>
					<p>{project.description}</p>
					<ul class="specs">
						{project.specs.map((s) => <li>{s}</li>)}
					</ul>
				</div>
			))}
		</main>
		<Footer />
	</body>
</html>
